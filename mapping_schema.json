{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Financial Data Mapping Schema",
  "description": "Stores how source columns from various file types map to standard destination fields.",
  "type": "object",
  "properties": {
    "file_type_id": {
      "type": "string",
      "description": "A unique identifier for the file format (e.g., 'stripe_payouts_v2', 'maybank_statement')"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "document_type": { "type": "string", "enum": ["bank_statement", "general_ledger", "invoice", "payroll", "tax_report"] },
        "country": { "type": "string" }
      }
    },
    "column_mapping": {
      "type": "object",
      "description": "Maps Standard Destination Fields (keys) to Source Columns (values).",
      "properties": {
        "Date": { "type": "string" },
        "Description": { "type": "string" },
        "Reference": { "type": "string" },
        "Debit": { "type": "string" },
        "Credit": { "type": "string" },
        "Amount": { "type": "string" },
        "Currency": { "type": "string" },
        "Balance": { "type": "string" },
        "Status": { "type": "string" },
        "Buyer_TIN": { "type": "string" },
        "Seller_TIN": { "type": "string" },
        "Tax_Amount": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "transformations": {
      "type": "object",
      "description": "Specific transformation rules for fields.",
      "properties": {
        "date_format": { "type": "string", "description": "e.g., 'DD/MM/YYYY'" },
        "number_format": { "type": "string", "enum": ["US", "EU"], "description": "US: 1,000.00, EU: 1.000,00" }
      }
    }
  },
  "required": ["file_type_id", "column_mapping"]
}
